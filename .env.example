# Which provider powers the agents: gemini | anthropic
LLM_PROVIDER=gemini

GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Model names change often — verify against current provider docs if a call fails.
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Resilience -------------------------------------------------------------
# Retries cover transient failures (HTTP 429, 5xx). They do NOT help with a
# daily quota being exhausted — that needs a provider switch or waiting.
MAX_RETRIES=4
RETRY_BASE_DELAY_SECONDS=1.0
LLM_REQUEST_TIMEOUT_SECONDS=60

# Token budget is tracked separately from step count — one large tool result
# can blow this without using many steps.
MAX_TOKENS_PER_TASK=300000
MAX_STEPS_PER_AGENT=15
TASK_TIMEOUT_SECONDS=600
REPETITION_LIMIT=3

# --- Sandboxing --------------------------------------------------------------
# Filesystem and exec tools are confined to this directory.
SANDBOX_DIR=./workspace
TOOL_EXEC_TIMEOUT_SECONDS=30

# --- Guardrails ---------------------------------------------------------------
# Comma-separated regex patterns. Leave unset to use the built-in default
# deny-list (rm, sudo, git push, pip install, curl, etc.) — setting this
# REPLACES the defaults entirely, it doesn't add to them.
DENIED_COMMAND_PATTERNS=
MAX_WRITE_BYTES=1000000

# --- Tracing -------------------------------------------------------------------
# One JSONL file per task under this directory.
TRACE_DIR=./traces
# $ cost is 0 until you fill these in from current provider pricing pages —
# not hardcoded here since prices change and go stale.
GEMINI_INPUT_PRICE_PER_MILLION=0.0
GEMINI_OUTPUT_PRICE_PER_MILLION=0.0
ANTHROPIC_INPUT_PRICE_PER_MILLION=0.0
ANTHROPIC_OUTPUT_PRICE_PER_MILLION=0.0

DB_PATH=orchestrator_state.db
